---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
---

<BaseLayout>
  <main class="max-w-3xl mx-auto px-6 py-20 md:py-32 font-sans">
    
    <!-- Hero -->
    <section class="mb-32">
      <h1
        class="text-4xl md:text-5xl font-bold tracking-tight mb-8 font-mono text-white leading-tight"
      >
        Dekonditionierung.<br />
    </section>

    <!-- Im Fluss -->
    <section class="mb-32">
      <span
        class="block text-xs font-mono text-gray-600 uppercase tracking-widest mb-10"
        >Im Fluss</span
      >

      <div class="space-y-10">
        <a
          href="/vision.html"
          class="block group border-t border-white/10 pt-6 hover:border-white/40 transition-colors"
        >
          <div
            class="text-xs font-mono text-gray-600 uppercase tracking-widest mb-2"
          >
            Lesestück · April 2026
          </div>
          <h2
            class="text-xl md:text-2xl font-mono text-gray-300 group-hover:text-white transition-colors leading-snug"
          >
            Das Web bekommt ein zweites Gesicht.
          </h2>
          <p class="text-sm font-mono text-gray-500 mt-2">
            Wie Agenten als neues Publikum ankommen — und was das für
            alle bedeutet, die Wissen haben.
          </p>
        </a>

        <a
          href="/lesestueck.html"
          class="block group border-t border-white/10 pt-6 hover:border-white/40 transition-colors"
        >
          <div
            class="text-xs font-mono text-gray-600 uppercase tracking-widest mb-2"
          >
            Lesestück · April 2026
          </div>
          <h2
            class="text-xl md:text-2xl font-mono text-gray-300 group-hover:text-white transition-colors leading-snug"
          >
            Etwas hat sich verschoben. Leise. Aber für immer.
          </h2>
          <p class="text-sm font-mono text-gray-500 mt-2">
            Über lokale KI im Smartphone und was das für Wissen
            bedeutet, das bisher in der Cloud stattfinden musste.
          </p>
        </a>

        <a
          href="/skills.html"
          class="block group border-t border-white/10 pt-6 hover:border-white/40 transition-colors"
        >
          <div
            class="text-xs font-mono text-gray-600 uppercase tracking-widest mb-2"
          >
            Angebot · laufend
          </div>
          <h2
            class="text-xl md:text-2xl font-mono text-gray-300 group-hover:text-white transition-colors leading-snug"
          >
            Dein Wissen, verpackt als Skill.
          </h2>
          <p class="text-sm font-mono text-gray-500 mt-2">
            Einmal-Auftrag statt Retainer. Drei Varianten. Was ich
            baue und wie.
          </p>
        </a>
      </div>
    </section>


<!-- Footer -->
    <footer class="border-t border-white/10 pt-12 pb-20">
      <div
        class="flex flex-col md:flex-row gap-12 text-sm font-mono text-gray-500"
      >

        <div>
          <span
            class="block text-xs uppercase tracking-widest mb-3 text-gray-700"
            >Kontakt</span
          >
          <details class="group">
            <summary
              class="cursor-pointer text-gray-400 hover:text-white transition-colors font-mono border-b border-transparent hover:border-white inline-block list-none"
            >
              <span class="group-open:hidden">Schreib mir.</span>
              <span class="hidden group-open:inline">Schliessen</span>
            </summary>

            <div class="mt-8 max-w-xl">
              <ContactForm compact={true} />
            </div>
          </details>
        </div>

        <div class="md:ml-auto">
          <span
            class="block text-xs uppercase tracking-widest mb-3 text-gray-700"
            >Legal</span
          >
          <a
            href="/rechtliches"
            class="text-gray-400 hover:text-white transition-colors font-mono border-b border-transparent hover:border-white"
            >Impressum & Datenschutz</a
          >
        </div>
      </div>
    </footer>

  </main>
</BaseLayout>
