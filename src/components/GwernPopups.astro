---
/**
 * GwernPopups.astro — Universelle Gwern-Popup-Komponente
 *
 * Passt sich automatisch an das Layout an. Benötigt KEINEN spezifischen
 * Selektor vom Aufrufer. Der Content-Container wird automatisch gefunden.
 *
 * document.main Fallback-Kette: .markdownBody → main → article → section → body
 *
 * Load-Reihenfolge:
 *   initial.js → utility.js → transclude-stub.js → content.js → popups.js
 *   → popins.js → annotations.js → extracts.js → extracts-annotations.js
 *   → extracts-content.js → extracts-options.js → extracts-load.js
 *
 * Verwendung:
 *   import GwernPopups from 'astro-gwern-popups/components/GwernPopups.astro';
 *   <GwernPopups />
 *
 *   Mit eigenem Annotations-Pfad:
 *   <GwernPopups annotationsJsonPath="/pfad/zu/annotations.json" />
 */

import fs from "node:fs";
import path from "node:path";

interface Props {
  /** Pfad zu annotations.json relativ zum Projekt-Root (default: "public/annotations.json") */
  annotationsJsonPath?: string;
  /** Pfad zu _index.json relativ zum Projekt-Root (default: "public/metadata/annotation/_index.json") */
  annotationIndexPath?: string;
  /** CSS-Pfad für gwern-popups.css (default: "/css/gwern-popups.css") */
  cssPath?: string;
}

const {
  annotationsJsonPath = "public/annotations.json",
  annotationIndexPath = "public/metadata/annotation/_index.json",
  cssPath = "/css/gwern-popups.css",
} = Astro.props;

// Annotation-Keys und Index beim Build einlesen
const annotationsFile = path.join(process.cwd(), annotationsJsonPath);
const indexFile = path.join(process.cwd(), annotationIndexPath);

let annotationKeys: string[] = [];
let annotationIndex: Record<string, string> = {};

try {
  const data = JSON.parse(fs.readFileSync(annotationsFile, "utf-8"));
  annotationKeys = Object.keys(data);
} catch (_e) {
  // Keine annotations.json vorhanden. Popups funktionieren ohne Annotationen (kein Fehler).
}

try {
  annotationIndex = JSON.parse(fs.readFileSync(indexFile, "utf-8"));
} catch (_e) {
  // Kein Index vorhanden. Popups funktionieren ohne Index (kein Fehler).
}
---

<!-- Gwern Popup CSS -->
<link rel="stylesheet" href={cssPath} />

<!--
  Build-Zeit Injection: Annotation-Keys + Index.
  Markiert Links mit link-annotated BEVOR Extracts.setup() läuft.
-->
<script is:inline define:vars={{ annotationKeys, annotationIndex }}>
(function() {
  // Index für annotations.js verfügbar machen
  window.__annotationIndex = annotationIndex;

  function normalizeToKey(href) {
    try {
      var u = new URL(href, window.location.origin);
      if (u.hostname === window.location.hostname) {
        return u.pathname.replace(/\/$/, "") || "/";
      }
      return u.hostname + u.pathname.replace(/\/$/, "");
    } catch (e) {
      return href;
    }
  }

  var keySet = new Set(annotationKeys);

  function markAnnotatedLinks(container) {
    container.querySelectorAll("a[href]").forEach(function(link) {
      var key = normalizeToKey(link.getAttribute("href"));
      if (keySet.has(key)) {
        link.classList.add("link-annotated");
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function() {
      markAnnotatedLinks(document);
    });
  } else {
    markAnnotatedLinks(document);
  }
})();
</script>

<!--
  document.main: Dynamisch gesetzt. Kein hartcodierter Selektor.
  Fallback-Kette: .markdownBody → main → article → section → body
-->
<script is:inline>
(function() {
  function findContentContainer() {
    return (
      document.querySelector(".markdownBody") ||
      document.querySelector("#markdownBody") ||
      document.querySelector("main") ||
      document.querySelector("article") ||
      document.querySelector("section") ||
      document.body
    );
  }

  Object.defineProperty(document, "main", {
    get: function() {
      return this._main || findContentContainer();
    },
    set: function(v) {
      this._main = v;
    },
    configurable: true,
  });
})();
</script>

