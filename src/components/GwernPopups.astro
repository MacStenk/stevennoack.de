<!-- Gwern Bundle (minified, defer für Performance) -->
<script src="/js/gwern-bundle.min.js" is:inline></script>
<script src="/js/popup-styles.js" is:inline></script>

<style is:global>
  /* Popup z-index über allem */
  #popup-container {
    z-index: 99999 !important;
  }

  /* Link-Indikator: ° nach annotierten Links */
  a.link-annotated:not(.no-indicator)::after {
    content: "\00B0";
    font-size: 0.65em;
    vertical-align: super;
    margin-left: 1px;
    opacity: 0.45;
    font-weight: normal;
  }

  /* Kein Indikator in Nav/Footer */
  nav a.link-annotated::after,
  footer a.link-annotated::after {
    content: none;
  }

  /* Popup-Link Highlight wenn offen */
  a.popup-open {
    background-color: rgba(100, 149, 237, 0.15);
    border-radius: 2px;
  }
</style>
