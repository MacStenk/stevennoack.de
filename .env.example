# stevennoack.de - Environment variables
# Copy to .env (or .env.local) and fill values.

# === Sentry ===
# Public DSN used by both client + server SDKs.
PUBLIC_SENTRY_DSN=

# === Resend ===
# API-Key für den Mail-Versand aus dem Kontaktformular.
# Erstellen unter https://resend.com/api-keys
RESEND_API_KEY=
