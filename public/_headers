/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://stats.stevennoack.de; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://stats.stevennoack.de; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Access-Control-Allow-Origin: https://stevennoack.de

/.well-known/*
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin

/api/*
  Access-Control-Allow-Origin: *
