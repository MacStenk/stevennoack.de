/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://stats.stevennoack.de https://assets.mailerlite.com https://assets.mlcdn.com; style-src 'self' 'unsafe-inline' https://assets.mlcdn.com; img-src 'self' data: https:; connect-src 'self' https://stats.stevennoack.de https://assets.mailerlite.com https://*.mailerlite.com; font-src 'self' https://assets.mlcdn.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://*.mailerlite.com
  Cross-Origin-Opener-Policy: same-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Resource-Policy: cross-origin

/.well-known/*
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin

/api/*
  Access-Control-Allow-Origin: *

/images/*
  Access-Control-Allow-Origin: *
